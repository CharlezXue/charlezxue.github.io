  <body>
    <div class="grain" aria-hidden="true"></div>
    <div class="floating-sphere s1" aria-hidden="true"></div>
    <div class="floating-sphere s2" aria-hidden="true"></div>
    <div class="floating-sphere s3" aria-hidden="true"></div>
    <audio id="bgm" src="/background.mp3" preload="metadata" loop></audio>
    <button id="music-toggle" class="music-toggle" aria-label="Toggle background music">
      <svg class="icon-mute" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M11 5 6 9H2v6h4l5 4V5Z"/>
        <line x1="23" y1="9" x2="17" y2="15"/>
        <line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
      <svg class="icon-play" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M11 5 6 9H2v6h4l5 4V5Z"/>
      </svg>
    </button>
    <slot />
  </body>

  <script>
    const audio = document.getElementById('bgm');
    const toggle = document.getElementById('music-toggle');
    let started = false;

    function start() {
      if (started) return;
      started = true;
      audio.volume = 0.12;
      const seek = () => {
        if (audio.duration && isFinite(audio.duration)) {
          audio.currentTime = Math.random() * audio.duration;
        }
        audio.play().catch(() => {});
      };
      if (audio.readyState >= 1) {
        seek();
      } else {
        audio.addEventListener('loadedmetadata', seek, { once: true });
      }
      toggle.classList.add('playing');
      document.removeEventListener('click', start);
      document.removeEventListener('touchstart', start);
    }

    document.addEventListener('click', start);
    document.addEventListener('touchstart', start);

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      if (audio.paused) {
        audio.play().catch(() => {});
        toggle.classList.add('playing');
      } else {
        audio.pause();
        toggle.classList.remove('playing');
      }
    });
  </script>
